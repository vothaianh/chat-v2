NODE_ENV=development
PORT=3000

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=chat
DB_PASSWORD=chat
DB_NAME=chatdb
DB_SYNCHRONIZE=true

# JWT
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d

# CORS / sockets
CORS_ORIGIN=*
SOCKET_IO_PATH=/socket.io

# Optional Firebase (push). Leave empty to stub push as console logs.
# Create a service account JSON, base64 it, and paste here:
#   cat serviceAccount.json | base64 | tr -d '\n'
FIREBASE_CREDENTIALS_BASE64=
FIREBASE_PROJECT_ID=